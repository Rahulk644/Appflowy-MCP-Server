# --- AppFlowy Cloud credentials (required) ---
# AppFlowy has no scoped API keys — this is a full-account login. Use a
# DEDICATED bot account invited to only the workspace(s) you want to expose.
APPFLOWY_EMAIL=bot@example.com
APPFLOWY_PASSWORD=your_password
# Override only if self-hosting AppFlowy Cloud:
# APPFLOWY_BASE_URL=https://beta.appflowy.cloud

# --- Endpoint auth (required for any network/remote deployment) ---
# Clients must send: Authorization: Bearer <this value>. Generate with:
#   openssl rand -hex 32
MCP_SECRET_TOKEN=change_me_to_a_long_random_hex

# --- Workspace scoping (strongly recommended) ---
# Comma-separated workspace ids the server may touch. Every tool refuses any
# other id. Leave unset to allow all workspaces the account can see.
# ALLOWED_WORKSPACE_IDS=00000000-0000-0000-0000-000000000000

# --- DNS-rebinding protection for the HTTP transports ---
# Set to your public host(s) when behind a reverse proxy / tunnel.
# MCP_ALLOWED_HOSTS=mcp.example.com
# MCP_ALLOWED_ORIGINS=https://mcp.example.com
# MCP_DNS_REBINDING_PROTECTION=true

# --- Docker/Traefik only ---
# Host that Traefik routes to (used by docker-compose.yaml label interpolation).
# MCP_HOST=mcp.example.com

# --- Google OAuth sign-in (optional) ---
# Enables "Connect -> sign in with Google" instead of a shared token: clients add
# the server with just its URL, no token in the link. Create a Google OAuth *Web*
# client whose redirect URI is <OAUTH_ISSUER>/auth/google/callback, then set:
# GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your_google_client_secret
# ALLOWED_EMAILS=you@example.com,teammate@example.com
# OAUTH_ISSUER=https://mcp.example.com
# Persist issued tokens + registered clients across restarts so a redeploy doesn't
# force re-sign-in. Point at a path on a MOUNTED VOLUME (a bare container path is
# wiped on rebuild). The file holds bearer/refresh tokens — keep the volume private
# (it's written 0600). Unset = in-memory (fine for local/stdio).
# OAUTH_STORE_PATH=/data/oauth-store.json
